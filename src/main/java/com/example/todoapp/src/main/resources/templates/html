<!DOCTYPE html>
<html>
<head>
    <title>Todo List</title>
</head>
<body>

<h1>📋 Task sắp đến hạn</h1>
<ul id="taskList"></ul>

<script>
fetch('/api/tasks/upcoming')
  .then(res => res.json())
  .then(tasks => {
    let html = "";
    tasks.forEach(t => {
      html += `<li><b>${t.title}</b> - ${t.deadline}</li>`;
    });
    document.getElementById("taskList").innerHTML = html;
  });
</script>

</body>
</html>